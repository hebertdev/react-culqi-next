{
  "name": "react-culqi-next",
  "description": "A React library for integration with the Culqi payment processor, compatible with Next.js",
  "version": "0.1.2",
  "license": "MIT",
  "contributors": [
    "Hebert Villafuerte (https://github.com/hebertdev/)"
  ],
  "author": "hebertdev",
  "repository": {
    "type": "git",
    "url": "https://github.com/hebertdev/react-culqi-next"
  },
  "homepage": "https://react-culqi-next.hebertdev.com/",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "size": "size-limit",
    "analyze": "size-limit --why",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=16"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 KB"
    },
    {
      "path": "dist/index.cjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.12",
    "@types/react-dom": "^18.2.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.0",
    "size-limit": "^8.2.4",
    "ts-jest": "^29.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.1.0"
  }
}
